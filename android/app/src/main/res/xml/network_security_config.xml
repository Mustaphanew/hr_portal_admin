<?xml version="1.0" encoding="utf-8"?>
<!--
    Production / release network security policy.

    HTTPS-only: cleartext traffic is BLOCKED everywhere. The debug build
    overrides this via android/app/src/debug/res/xml/network_security_config_debug.xml
    so the emulator can reach the local Laravel server.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
