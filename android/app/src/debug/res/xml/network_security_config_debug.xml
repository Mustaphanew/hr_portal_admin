<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext (HTTP) traffic to the development backend on the
    Android emulator (10.0.2.2 is how the emulator reaches the host machine).

    HTTPS remains the default everywhere else (production endpoints).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator → host machine -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Local loopback (USB/wifi debugging on physical device with adb reverse) -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Local network IP example (uncomment & adjust if you serve from LAN) -->
        <!-- <domain includeSubdomains="true">192.168.1.10</domain> -->
        <!-- Original LAN IP referenced by AppConfig.devBaseUrl -->
        <domain includeSubdomains="true">172.16.0.66</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
